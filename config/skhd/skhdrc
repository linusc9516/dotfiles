# ─── yabai window management ─────────────────────────
# Modifier: ctrl + alt (⌃ + ⌥)
# Use Caps Lock (which is Ctrl) + physical Alt

# Focus window (vim keys)
ctrl + alt - h : yabai -m window --focus west
ctrl + alt - j : yabai -m window --focus south
ctrl + alt - k : yabai -m window --focus north
ctrl + alt - l : yabai -m window --focus east

# Move window
ctrl + alt + shift - h : yabai -m window --warp west
ctrl + alt + shift - j : yabai -m window --warp south
ctrl + alt + shift - l : yabai -m window --warp east
ctrl + alt + shift - k : yabai -m window --warp north

# Resize window
# Arrow keys: expand/shrink in the obvious direction
# Shift + arrow: reverse the resize (shrink/expand opposite)
ctrl + alt - up        : yabai -m window --resize top:0:-20
ctrl + alt + shift - down : yabai -m window --resize top:0:20
ctrl + alt - down      : yabai -m window --resize bottom:0:20
ctrl + alt + shift - up : yabai -m window --resize bottom:0:-20
ctrl + alt - left      : yabai -m window --resize left:-20:0
ctrl + alt + shift - right : yabai -m window --resize left:20:0
ctrl + alt - right     : yabai -m window --resize right:20:0
ctrl + alt + shift - left : yabai -m window --resize right:-20:0

# Layout & spaces
ctrl + alt - f         : yabai -m window --toggle zoom-fullscreen
ctrl + alt - space     : yabai -m space --layout next
ctrl + alt - s         : yabai -m space --layout stack
ctrl + alt - b         : yabai -m space --layout bsp
ctrl + alt + shift - n : yabai -m window --space next
ctrl + alt + shift - p : yabai -m window --space prev
ctrl + alt - n         : yabai -m space --focus next
ctrl + alt - p         : yabai -m space --focus prev

# Float / unfloat
ctrl + alt - t         : yabai -m window --toggle float

# Misc
ctrl + alt - r         : yabai -m window --toggle split
ctrl + alt - e         : yabai -m space --balance